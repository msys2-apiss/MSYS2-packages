diff --git a/packages/gcc/15.2.0/mingw/0007-clone_function_name_1-Retain-any-stdcall-suffix.patch b/packages/gcc/15.2.0/mingw/0007-clone_function_name_1-Retain-any-stdcall-suffix.patch
