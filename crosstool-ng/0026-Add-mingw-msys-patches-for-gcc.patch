++      sprintf(__newloc, "%s/%s/%s/%s/%s/%s",
++	      __buf[0], __buf[1], __buf[2], __buf[3], __buf[4], __buf[5]);
++      __ret = setlocale(__category, __newloc);
++
++    }
++  return __ret;
