+ 5 files changed, 10 insertions(+), 10 deletions(-)
+
+diff --git a/gcc/testsuite/jit.dg/jit.exp b/gcc/testsuite/jit.dg/jit.exp
+index 57b133b6d8c..547518cb9ec 100644
