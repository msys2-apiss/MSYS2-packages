+--- a/gcc/pretty-print.cc
++++ b/gcc/pretty-print.cc
+@@ -3556,8 +3556,12 @@ test_custom_tokens_1 ()
+   ASSERT_EQ (e1.m_num_living_values, 0);
+   ASSERT_EQ (e2.m_num_living_values, 0);
+ 
