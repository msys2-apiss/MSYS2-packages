Subject: [PATCH 24/36] shared=y for host and build

---
 scripts/build/companion_libs/200-libelf.sh   | 2 ++
 scripts/build/companion_libs/210-expat.sh    | 1 +
 scripts/build/companion_libs/220-ncurses.sh  | 2 ++
 scripts/build/companion_libs/320-libiconv.sh | 2 ++
 scripts/build/companion_libs/330-gettext.sh  | 2 ++
 5 files changed, 9 insertions(+)

diff --git a/scripts/build/companion_libs/200-libelf.sh b/scripts/build/companion_libs/200-libelf.sh
index f0d8be47..84eacd57 100644
--- a/scripts/build/companion_libs/200-libelf.sh
+++ b/scripts/build/companion_libs/200-libelf.sh
@@ -35,6 +35,7 @@ do_libelf_for_build() {
     libelf_opts+=( "prefix=${CT_BUILDTOOLS_PREFIX_DIR}" )
     libelf_opts+=( "cflags=${CT_CFLAGS_FOR_BUILD}" )
     libelf_opts+=( "ldflags=${CT_LDFLAGS_FOR_BUILD}" )
+    libelf_opts+=( "shared=y" )
     do_libelf_backend "${libelf_opts[@]}"
 
     CT_Popd
@@ -52,6 +53,7 @@ do_libelf_for_host() {
     libelf_opts+=( "prefix=${CT_HOST_COMPLIBS_DIR}" )
     libelf_opts+=( "cflags=${CT_CFLAGS_FOR_HOST}" )
     libelf_opts+=( "ldflags=${CT_LDFLAGS_FOR_HOST}" )
+    libelf_opts+=( "shared=y" )
     do_libelf_backend "${libelf_opts[@]}"
 
     CT_Popd
diff --git a/scripts/build/companion_libs/210-expat.sh b/scripts/build/companion_libs/210-expat.sh
