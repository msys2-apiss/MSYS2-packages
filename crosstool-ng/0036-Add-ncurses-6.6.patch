@@ -0,0 +1,61 @@
+From 46cce7aa3e74077e6396ff38425996ad00eb49bd Mon Sep 17 00:00:00 2001
+From: Yonggang Luo <luoyonggang@gmail.com>
+Date: Wed, 28 Jan 2026 01:24:38 +0800
+Subject: [PATCH 1/3] ncurses config win paths
+
+---
+ misc/ncurses-config.in | 13 ++++++++-----
+ 1 file changed, 8 insertions(+), 5 deletions(-)
+
+diff --git a/misc/ncurses-config.in b/misc/ncurses-config.in
+index ea3ad0d2..fddab7a5 100644
+--- a/misc/ncurses-config.in
++++ b/misc/ncurses-config.in
+@@ -36,7 +36,7 @@ LANGUAGE=C;	export LANGUAGE
+ LC_ALL=C;	export LC_ALL
+ LC_CTYPE=C;	export LC_CTYPE
+ 
+-prefix="@prefix@"
++prefix="$(cygpath -m "@prefix@")"
+ exec_prefix="@exec_prefix@"
+ 
+ bindir="@bindir@"
+@@ -44,7 +44,7 @@ includedir="@includedir@"
+ libdir="@libdir@"
+ datarootdir="@datarootdir@"
+ datadir="@datadir@"
+-mandir="@mandir@"
++mandir="$(cygpath -m "@mandir@")"
+ 
+ CURSES_LIB="@LIB_NAME@@ABI_SUFFIX@"
+ TINFO_LIB="@TINFO_ARG_SUFFIX@"
+@@ -164,6 +164,9 @@ do
+ 				continue
+ 			fi
+ 			;;
++		$libdir) # skip standard libdir
++			continue
++			;;
+ 		*)
+ 			found=no
+ 			for check in $lib_flags
+@@ -330,13 +333,13 @@ while [ $# -gt 0 ]; do
+ 		echo "${mandir}"
+ 		;;
+ 	--terminfo)
+-		echo "@TERMINFO@"
++		echo "$(cygpath -m "@TERMINFO@")"
+ 		;;
+ 	--terminfo-dirs)
+-		echo "@TERMINFO_DIRS@"
++		echo "$(cygpath -m "@TERMINFO_DIRS@")"
+ 		;;
+ 	--termpath)
+-		echo "@TERMPATH@"
++		echo "$(cygpath -m "@TERMPATH@")"
+ 		;;
+ 	# general info
+ 	--help)
+-- 
+2.52.0.windows.1
+
diff --git a/packages/ncurses/6.6/mingw/0002-pkgconfig.patch b/packages/ncurses/6.6/mingw/0002-pkgconfig.patch
new file mode 100644
index 00000000..d2a74f89
--- /dev/null
+++ b/packages/ncurses/6.6/mingw/0002-pkgconfig.patch
@@ -0,0 +1,39 @@
+From 588f1f05609b783259fe75c2a6d65622ff3644b5 Mon Sep 17 00:00:00 2001
+From: Yonggang Luo <luoyonggang@gmail.com>
+Date: Wed, 28 Jan 2026 01:25:21 +0800
+Subject: [PATCH 2/3] pkgconfig
+
+---
+ misc/gen-pkgconfig.in  | 2 +-
+ misc/ncurses-config.in | 2 +-
+ 2 files changed, 2 insertions(+), 2 deletions(-)
+
+diff --git a/misc/gen-pkgconfig.in b/misc/gen-pkgconfig.in
+index c369dd26..abca88fe 100644
+--- a/misc/gen-pkgconfig.in
++++ b/misc/gen-pkgconfig.in
+@@ -83,7 +83,7 @@ if [ "$includedir" != "/usr/include" ]; then
+ fi
+ 
+ lib_flags=
+-for opt in -L$libdir @EXTRA_PKG_LDFLAGS@ @LIBS@
++for opt in -L$libdir @LIBS@
+ do
+ 	case $opt in
+ 	-l*) # LIBS is handled specially below
+diff --git a/misc/ncurses-config.in b/misc/ncurses-config.in
+index fddab7a5..13c6c149 100644
+--- a/misc/ncurses-config.in
++++ b/misc/ncurses-config.in
+@@ -110,7 +110,7 @@ fi
+ # There is no portable way to find the list of standard library directories.
+ # Require a POSIX shell anyway, to keep this simple.
+ lib_flags=
+-for opt in -L$libdir @EXTRA_PKG_LDFLAGS@ $LIBS
++for opt in -L$libdir $LIBS
+ do
+ 	case $opt in
+ 	-specs*) # ignore linker specs-files which were used to build library
+-- 
+2.52.0.windows.1
+
