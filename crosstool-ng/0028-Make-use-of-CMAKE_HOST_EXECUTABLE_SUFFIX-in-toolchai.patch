From 38f6bdb936510c71b464b756f1c0275b4bd73366 Mon Sep 17 00:00:00 2001
From: Yonggang Luo <luoyonggang@gmail.com>
Date: Fri, 26 Dec 2025 13:29:32 +0800
Subject: [PATCH 28/36] Make use of CMAKE_HOST_EXECUTABLE_SUFFIX in
 toolchain.cmake

Signed-off-by: Yonggang Luo <luoyonggang@gmail.com>
---
 scripts/build/internals.sh | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/scripts/build/internals.sh b/scripts/build/internals.sh
index 717bf24e..c6b09d89 100644
--- a/scripts/build/internals.sh
+++ b/scripts/build/internals.sh
@@ -39,8 +39,8 @@ create_cmake_toolchain()
 set(CMAKE_SYSTEM_NAME @@SYSTEM@@)
 set(CMAKE_SYSTEM_PROCESSOR @@CT_TARGET_ARCH@@)
 
-set(CMAKE_C_COMPILER \${CMAKE_CURRENT_LIST_DIR}/bin/@@CT_TARGET@@-gcc)
-set(CMAKE_CXX_COMPILER \${CMAKE_CURRENT_LIST_DIR}/bin/@@CT_TARGET@@-g++)
+set(CMAKE_C_COMPILER \${CMAKE_CURRENT_LIST_DIR}/bin/@@CT_TARGET@@-gcc\${CMAKE_HOST_EXECUTABLE_SUFFIX})
+set(CMAKE_CXX_COMPILER \${CMAKE_CURRENT_LIST_DIR}/bin/@@CT_TARGET@@-g++\${CMAKE_HOST_EXECUTABLE_SUFFIX})
 
 set(CMAKE_FIND_ROOT_PATH \${CMAKE_CURRENT_LIST_DIR}/@@CT_TARGET@@/sysroot)
 set(CMAKE_FIND_ROOT_PATH_MODE_PROGRAM NEVER)
-- 
