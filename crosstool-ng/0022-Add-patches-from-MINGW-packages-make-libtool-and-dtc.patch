++++ b/build-aux/ltmain.in
+@@ -7439,6 +7439,15 @@ func_mode_link ()
+ 			a_deplib=
+ 			break 2
+ 		      fi
++		      # Linking compiler provided static libraries into shared
++		      # libraries is allowed, but linking other static libraries is
++		      # non-portable.
++		      case $potlib in
++		        */libFortran*.$libext | */libflang_rt*.$libext)
