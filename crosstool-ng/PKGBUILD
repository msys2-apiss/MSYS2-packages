prepare() {
  install -Dm755 /usr/bin/bsdunzip "${srcdir}/bin/unzip"
  [[ -d ${srcdir}/${pkgname}-${pkgname}-${pkgver} ]] && rm -rf ${srcdir}/${pkgname}-${pkgname}-${pkgver}
  tar -xf ${srcdir}/${pkgname}-${pkgver}.tar.gz -C ${srcdir} || true
  
  cd "${srcdir}/${pkgname}-${pkgname}-${pkgver}"

  for patch_filename in "${_patches[@]}"; do
    echo "Applying patch: '${patch_filename}'"
    patch --binary -Np1 -i "${srcdir}/${patch_filename}"
  done

  ./bootstrap
}

build() {
  cd "${srcdir}/${pkgname}-${pkgname}-${pkgver}"
  PATH="${srcdir}/bin:$PATH" ./configure \
    --build=${CHOST} \
    --prefix=/usr

  PATH="${srcdir}/bin:$PATH" make
}

package() {
  cd "${srcdir}/${pkgname}-${pkgname}-${pkgver}"
  make DESTDIR=${pkgdir} install
}
