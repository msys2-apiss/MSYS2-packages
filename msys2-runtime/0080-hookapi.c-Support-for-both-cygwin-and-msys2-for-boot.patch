From b130a01154fa414b625c21a77211f38306deba36 Mon Sep 17 00:00:00 2001
From: Yonggang Luo <luoyonggang@gmail.com>
Date: Wed, 7 Jan 2026 17:08:33 +0800
Subject: [PATCH 80/80] hookapi.c: Support for both cygwin and msys2 for
 bootstrap

This is for bootstrap building msys2 as cygwin1.dll

This can be rebased before "Rename dll from cygwin to msys"
---
 winsup/cygwin/hookapi.cc | 7 ++++---
 1 file changed, 4 insertions(+), 3 deletions(-)

diff --git a/winsup/cygwin/hookapi.cc b/winsup/cygwin/hookapi.cc
index ee2edbafe..49974f8c3 100644
--- a/winsup/cygwin/hookapi.cc
+++ b/winsup/cygwin/hookapi.cc
@@ -378,9 +378,10 @@ hook_or_detect_cygwin (const char *name, const void *fn, WORD& subsys, HANDLE h)
   // Iterate through each import descriptor, and redirect if appropriate
   for (PIMAGE_IMPORT_DESCRIPTOR pd = pdfirst; pd->FirstThunk; pd++)
     {
-      if (!ascii_strcasematch (rva (PSTR, map ?: (char *) hm, pd->Name - delta),
-			       "cygwin1.dll"))
-	continue;
+      char *name_to_compare = rva (PSTR, map ?: (char *) hm, pd->Name - delta);
+      bool not_msys2 = !ascii_strcasematch (name_to_compare, "msys-2.0.dll");
+      bool not_cygwin = !ascii_strcasematch (name_to_compare, "cygwin1.dll");
+      if (not_msys2 && not_cygwin) continue;
       if (!fn)
 	{
 	  /* Just checking if executable used cygwin1.dll. */
-- 
