From de546f77655c8e4459b6eb5d5ea0e71a65e1a2e4 Mon Sep 17 00:00:00 2001
From: Yonggang Luo <luoyonggang@gmail.com>
Date: Tue, 13 Jan 2026 16:38:16 +0800
Subject: [PATCH 1/2] fixes for cygwin build

---
 src/chartype.h          | 2 +-
 src/editline/readline.h | 2 +-
 src/sys.h               | 4 ++++
 3 files changed, 6 insertions(+), 2 deletions(-)

diff --git a/src/chartype.h b/src/chartype.h
index bcdb293..e3c7583 100644
--- a/src/chartype.h
+++ b/src/chartype.h
@@ -51,7 +51,7 @@
 /* Oh for a <uchar.h> with char32_t and __STDC_UTF_32__ in it...
  * ref: ISO/IEC DTR 19769
  */
-#if WCHAR_MAX < INT32_MAX
+#if WCHAR_MAX < INT32_MAX && !defined(__CYGWIN__)
 #warning Build environment does not support non-BMP characters
 #endif
 
diff --git a/src/editline/readline.h b/src/editline/readline.h
index 03e2d2e..f685546 100644
--- a/src/editline/readline.h
+++ b/src/editline/readline.h
@@ -78,7 +78,7 @@ typedef KEYMAP_ENTRY *Keymap;
 
 #ifndef CTRL
 #include <sys/ioctl.h>
-#if !defined(__sun) && !defined(__hpux) && !defined(_AIX)
+#if !defined(__sun) && !defined(__hpux) && !defined(_AIX) && !defined(__CYGWIN__)
 #include <sys/ttydefaults.h>
 #endif
 #ifndef CTRL
diff --git a/src/sys.h b/src/sys.h
index 0511bad..f635479 100644
--- a/src/sys.h
+++ b/src/sys.h
@@ -63,7 +63,11 @@
 #endif
 
 /* If your compiler does not support this, define it to be empty. */
+#ifdef __CYGWIN__
+#define libedit_private
+#else
 #define libedit_private __attribute__((__visibility__("hidden")))
+#endif
 
 #ifndef __arraycount
 # define __arraycount(a) (sizeof(a) / sizeof(*(a)))
-- 
2.52.0.windows.1

