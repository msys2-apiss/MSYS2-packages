From f6cc61c3a39ed75081e64f11766239231131bc7f Mon Sep 17 00:00:00 2001
From: Yonggang Luo <luoyonggang@gmail.com>
Date: Tue, 13 Jan 2026 16:39:02 +0800
Subject: [PATCH 2/2] fixes compiling with gcc 15 by use wchar_t

---
 src/el.h       |  4 ++--
 src/read.c     |  1 +
 src/refresh.c  |  4 ++--
 src/terminal.c | 10 +++++-----
 4 files changed, 10 insertions(+), 9 deletions(-)

diff --git a/src/el.h b/src/el.h
index c50ecbd..b08d419 100644
--- a/src/el.h
+++ b/src/el.h
@@ -119,8 +119,8 @@ struct editline {
 	int		  el_errfd;	/* Error file descriptor	*/
 	int		  el_flags;	/* Various flags.		*/
 	coord_t		  el_cursor;	/* Cursor location		*/
-	wint_t		**el_display;	/* Real screen image = what is there */
-	wint_t		**el_vdisplay;	/* Virtual screen image = what we see */
+	wchar_t		**el_display;	/* Real screen image = what is there */
+	wchar_t		**el_vdisplay;	/* Virtual screen image = what we see */
 	void		 *el_data;	/* Client data			*/
 	el_line_t	  el_line;	/* The current line information	*/
 	el_state_t	  el_state;	/* Current editor state		*/
diff --git a/src/read.c b/src/read.c
index 8026ca4..9485afe 100644
--- a/src/read.c
+++ b/src/read.c
@@ -51,6 +51,7 @@ __RCSID("$NetBSD: read.c,v 1.108 2022/10/30 19:11:31 christos Exp $");
 #include <stdlib.h>
 #include <string.h>
 #include <unistd.h>
+#include <sys/ioctl.h>
 
 #include "el.h"
 #include "fcns.h"
diff --git a/src/refresh.c b/src/refresh.c
index 543a53f..c36e0d5 100644
--- a/src/refresh.c
+++ b/src/refresh.c
@@ -105,7 +105,7 @@ re_nextline(EditLine *el)
 	 */
 	if (el->el_refresh.r_cursor.v + 1 >= el->el_terminal.t_size.v) {
 		int i, lins = el->el_terminal.t_size.v;
-		wint_t *firstline = el->el_vdisplay[0];
+		wchar_t *firstline = el->el_vdisplay[0];
 
 		for(i = 1; i < lins; i++)
 			el->el_vdisplay[i - 1] = el->el_vdisplay[i];
@@ -1094,7 +1094,7 @@ re_refresh_cursor(EditLine *el)
 static void
 re_fastputc(EditLine *el, wint_t c)
 {
-	wint_t *lastline;
+	wchar_t *lastline;
 	int w;
 
 	w = wcwidth(c);
diff --git a/src/terminal.c b/src/terminal.c
index 895a217..d96a064 100644
--- a/src/terminal.c
+++ b/src/terminal.c
@@ -413,10 +413,10 @@ terminal_rebuffer_display(EditLine *el)
 	return 0;
 }
 
-static wint_t **
+static wchar_t **
 terminal_alloc_buffer(EditLine *el)
 {
-	wint_t **b;
+	wchar_t **b;
 	coord_t *c = &el->el_terminal.t_size;
 	int i;
 
@@ -437,10 +437,10 @@ terminal_alloc_buffer(EditLine *el)
 }
 
 static void
-terminal_free_buffer(wint_t ***bp)
+terminal_free_buffer(wchar_t ***bp)
 {
-	wint_t **b;
-	wint_t **bufp;
+	wchar_t **b;
+	wchar_t **bufp;
 
 	if (*bp == NULL)
 		return;
-- 
2.52.0.windows.1

