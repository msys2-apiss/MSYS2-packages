From fdc8db2e0971f8ae8d30433525829abf9a31e5f9 Mon Sep 17 00:00:00 2001
From: Yonggang Luo <luoyonggang@gmail.com>
Date: Wed, 31 Dec 2025 20:54:54 +0800
Subject: [PATCH] Prepare to merge msys into cygwin

---
 Modules/Platform/MSYS.cmake | 7 +++++--
 1 file changed, 5 insertions(+), 2 deletions(-)

diff --git a/Modules/Platform/MSYS.cmake b/Modules/Platform/MSYS.cmake
index 468718d005..8f73ac0cc0 100644
--- a/Modules/Platform/MSYS.cmake
+++ b/Modules/Platform/MSYS.cmake
@@ -1,3 +1,6 @@
 include(Platform/CYGWIN)
-set(CMAKE_SHARED_LIBRARY_PREFIX "msys-")
-set(CMAKE_SHARED_MODULE_PREFIX "msys-")
+
+if ("$ENV{MSYSTEM}" STREQUAL "MSYS")
+  set(CMAKE_SHARED_LIBRARY_PREFIX "msys-")
+  set(CMAKE_SHARED_MODULE_PREFIX "msys-")
+endif()
